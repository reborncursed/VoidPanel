local function getRoot()
    local c = LP.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function isAlive(p)
    if not p or not p.Character then return false end
    local h = p.Character:FindFirstChildOfClass("Humanoid")
    return h and h.Health > 0
end

local function getHP(p)
    if not p or not p.Character then return 0,0 end
    local h = p.Character:FindFirstChildOfClass("Humanoid")
    if not h then return 0,0 end
    return math.floor(h.Health), math.floor(h.MaxHealth)
end

local function getHPPercent(p)
    local hp,maxhp = getHP(p)
    if maxhp == 0 then return 0 end
    return math.floor((hp/maxhp)*100)
end

local function getBounty(p)
    local d = p:FindFirstChild("leaderstats") or p:FindFirstChild("Data")
    if d then
        local b = d:FindFirstChild("Bounty") or d:FindFirstChild("Kills")
        return b and b.Value or 0
    end
    return 0
end

local function getLevel(p)
    local d = p:FindFirstChild("leaderstats") or p:FindFirstChild("Data")
    if d then
        local lv = d:FindFirstChild("Level") or d:FindFirstChild("Lv")
        return lv and lv.Value or 0
    end
    return 0
end

local function formatNum(n)
    if n >= 1000000 then return string.format("$%.2fM", n/1000000)
    elseif n >= 1000 then return string.format("$%.1fK", n/1000)
    else return "$"..tostring(n) end
end

local function hideName(name)
    return string.rep("*", #name)
end

local function teleportTo(target)
    local root = getRoot()
    if not root or not target or not target.Character then return end
    local tr = target.Character:FindFirstChild("HumanoidRootPart")
    if tr then root.CFrame = tr.CFrame * CFrame.new(0,0,-2.5) end
end

local function useSkills()
    local skills = FruitSkills[CFG.SelectedFruit]
    if not skills then return end
    for _,key in pairs(skills) do
        pcall(function()
            UserInputService.InputBegan:Fire(
                {KeyCode=Enum.KeyCode[key], UserInputType=Enum.UserInputType.Keyboard}, false
            )
        end)
        task.wait(0.005)
    end
end

local function killTarget(target)
    if not target or not isAlive(target) then return end
    teleportTo(target)
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        if remotes then
            for _,v in pairs(remotes:GetChildren()) do
                if v:IsA("RemoteEvent") then
                    pcall(function() v:FireServer(target.Character) end)
                end
            end
        end
    end)
    if CFG.FruitSupport then useSkills() end
    if CFG.InstantKill then
        for i = 1,50 do
            teleportTo(target)
            pcall(function()
                local remotes = ReplicatedStorage:FindFirstChild("Remotes")
                if remotes then
                    for _,v in pairs(remotes:GetChildren()) do
                        if v:IsA("RemoteEvent") then
                            pcall(function() v:FireServer(target.Character) end)
                        end
                    end
                end
            end)
            task.wait(0)
            if not isAlive(target) then
                killCount = killCount + 1
                serverKills = serverKills + 1
                gainedBounty = gainedBounty + getBounty(target)
                break
            end
        end
    end
end

local function findBestTarget()
    local best, lowestHP = nil, math.huge
    for _,p in pairs(Players:GetPlayers()) do
        if p == LP then continue end
        if not isAlive(p) then continue end
        if CFG.SelectedTeam == "Pirates" and (p.Team and p.Team.Name ~= "Pirates") then continue end
        if CFG.SelectedTeam == "Marines" and (p.Team and p.Team.Name ~= "Marines") then continue end
        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health < lowestHP then
            lowestHP = hum.Health
            best = p
        end
    end
    return best
end

local function hasPVPPlayer()
    for _,p in pairs(Players:GetPlayers()) do
        if p == LP then continue end
        if isAlive(p) then return true end
    end
    return false
end

local function hopServer()
    if hopCooldown then return end
    hopCooldown = true
    pcall(function() TeleportService:Teleport(game.PlaceId, LP) end)
    task.wait(10)
    hopCooldown = false
end

