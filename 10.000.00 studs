local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local LP = Players.LocalPlayer

local CFG = {
    ScaleOn = false,
    ScaleSize = 2000,
}

local scaleConn = nil

local function setScale(size)
    local char = LP.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    for _, name in pairs({"BodyHeightScale","BodyWidthScale","BodyDepthScale","HeadScale"}) do
        local s = hum:FindFirstChild(name)
        if s then s.Value = size end
    end
end

local function startScale()
    if scaleConn then scaleConn:Disconnect() end
    scaleConn = RunService.Heartbeat:Connect(function()
        if CFG.ScaleOn then setScale(CFG.ScaleSize) end
    end)
    LP.CharacterAdded:Connect(function()
        task.wait(1)
        if CFG.ScaleOn then setScale(CFG.ScaleSize) end
    end)
end

local ScreenGui = Instance.new("ScreenGui")
