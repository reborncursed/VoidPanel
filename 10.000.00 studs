local function updateToggle()
    local on=CFG.ScaleOn
    tw(pill,{BackgroundColor3=on and C.purple or C.purpleD},0.2)
    tw(dot,{Position=on and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9)},0.2)
    tw(dot,{BackgroundColor3=on and Color3.new(1,1,1) or Color3.fromRGB(120,100,160)},0.2)
    tw(toggleBtn,{BackgroundColor3=on and C.sur2 or C.purpleD},0.2)
    toggleDesc.Text=on and "ON — 2000x active! 🔥" or "OFF — Click to enable"
    toggleDesc.TextColor3=on and C.green or C.dim
    statusLbl.Text=on and "Status: ACTIVE 🔥" or "Status: OFF"
    statusLbl.TextColor3=on and C.green or C.dim
    if on then setScale(CFG.ScaleSize)
    else setScale(1) end
end

toggleBtn.MouseButton1Click:Connect(function()
    CFG.ScaleOn=not CFG.ScaleOn
    updateToggle()
end)

local drag,ds,sp=false,nil,nil
TBar.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
        drag=true;ds=i.Position;sp=Main.Position
    end
end)
TBar.InputEnded:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
end)
UserInputService.InputChanged:Connect(function(i)
    if drag and (i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseMovement) then
        local d=i.Position-ds
        Main.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)
    end
end)

startScale()
tw(Main,{Size=UDim2.new(0,W,0,H)},0.4)
print("[VoidAvatarScale 2000x] Loaded! by CursedExility")
